{
  "name": "morrison-api",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "clean:proto": "rm -rf src/generated",
    "generate:proto": "grpc_tools_node_protoc --plugin=protoc-gen-ts_proto=./node_modules/.bin/protoc-gen-ts_proto --proto_path=../contracts --ts_proto_out=./src/generated --ts_proto_opt=outputServices=grpc-js,env=node ../contracts/*.proto",
    "refresh:proto": "pnpm clean:proto && pnpm generate:proto"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.12.1",
    "@grpc/grpc-js": "^1.14.4",
    "@hono/node-server": "^2.0.8",
    "@hono/zod-validator": "^0.8.0",
    "dotenv": "^17.4.2",
    "hono": "^4.12.28",
    "nodemailer": "^9.0.3",
    "puppeteer": "^25.3.0",
    "ssh2-sftp-client": "^12.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.17",
    "@types/nodemailer": "^8.0.1",
    "@types/ssh2-sftp-client": "^9.0.6",
    "grpc-tools": "^1.13.1",
    "ts-proto": "^2.12.0",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3"
  }
}